# Play Right with AI Configuration
# Copy this file to .env and update with your actual values

# GitHub Repository
GITHUB_REPO=https://github.com/clarencechien/play-right-with-ai

# Google Analytics
# Get your measurement ID from https://analytics.google.com/
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Deployment
DEPLOY_URL=https://clarencechien.github.io/play-right-with-ai/

# API Configuration (optional)
API_ENDPOINT=https://api.your-domain.com

# Environment
NODE_ENV=development

# Build Configuration
BUILD_OUTPUT_DIR=docs
CONTENT_SOURCE_DIR=content

# Link Validation
LINK_VALIDATION_TIMEOUT=5000
LINK_VALIDATION_RETRIES=3
