{
  "all": true,
  "include": [
    "src/**/*.{js,ts}",
    "workshop/**/*.{js,ts}",
    "tests/**/*.{js,ts}"
  ],
  "exclude": [
    "**/*.spec.{js,ts}",
    "**/*.test.{js,ts}",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.config.{js,ts}"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": true,
  "per-file": false,
  "lines": 80,
  "statements": 80,
  "functions": 80,
  "branches": 70,
  "watermarks": {
    "lines": [80, 95],
    "functions": [80, 95],
    "branches": [70, 90],
    "statements": [80, 95]
  }
}